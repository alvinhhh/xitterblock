{
  "manifest_version": 3,
  "name": "X Ad & Paid Promotion Blocker",
  "version": "1.1.0",
  "description": "Hides promoted ads and paid-partnership tweets on X/Twitter.",
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
